# Painel de Performance — Variáveis de ambiente
# Copie para .env e preencha os valores. Não commitar .env real.

# Secret pra assinar JWTs. Gera um aleatório:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# Porta do servidor Express. Default: 3004
PORT=3004

# === Meta Marketing API (Facebook/Instagram Ads) ===
# Token permanente do System User no Business Manager.
# Permissões: ads_read, business_management.
META_ACCESS_TOKEN=

# === Kiwify (vendas/checkout) ===
# OAuth2 client. Pegar em Configurações → API/Webhooks no painel Kiwify.
KIWIFY_CLIENT_ID=
KIWIFY_CLIENT_SECRET=
KIWIFY_ACCOUNT_ID=

# === Google Ads API ===
# Developer token: aprovado pelo Google em ads.google.com/aw/apicenter
GOOGLE_ADS_DEVELOPER_TOKEN=

# OAuth2 client (Cloud Console → APIs & Services → Credentials)
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=

# Refresh token gerado pelo fluxo OAuth (rota /api/google-ads/auth)
GOOGLE_ADS_REFRESH_TOKEN=

# MCC ID (manager account) — sem hifens. Ex: 1234567890
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# Redirect URI registrada no OAuth client. Em prod: https://drosagencia.com.br/core/api/google-ads/callback
GADS_REDIRECT_URI=
