# Instagram Graph API — https://developers.facebook.com/docs/instagram-api/
# Requires an Instagram Business account connected to a Facebook Page.
# Get your token from: Meta for Developers → Graph API Explorer
# Required scope: instagram_content_publish

INSTAGRAM_ACCESS_TOKEN=your_long_lived_access_token_here
INSTAGRAM_USER_ID=your_instagram_business_user_id_here

# Image hosting: catbox.moe is used automatically (no API key needed)
